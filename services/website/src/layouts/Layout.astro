---
import { ViewTransitions } from "astro:transitions";
import { pwaInfo } from "virtual:pwa-info";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import "@fontsource-variable/inter";
import "@fontsource/young-serif";
import { SEO } from "astro-seo";

export interface Props {
  title?: string;
  lang?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/meta/opengraph.png",
  Astro.site,
).toString();

const { title, lang: _lang = null } = Astro.props;

const makeTitle = title
  ? `${title} | InfraLayer`
  : "InfraLayer - Composable, OpenSource AI DevOps Copilot";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />
    <ViewTransitions />

    <!-- Global CSS -->
    <link rel="stylesheet" href="/index.css" />

    <SEO
      title={makeTitle}
      description="InfraLayer automates infrastructure monitoring, cost optimization, and cloud troubleshooting so your team can focus on shipping great software."
      canonical={canonicalURL}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `InfraLayer - Composable, OpenSource AI DevOps Copilot`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "InfraLayer Homepage Screenshot",
        },
      }}
    />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <script src="/src/pwa.ts"></script>
  </head>
  <body>
    <div
      x-data="{ show: !sessionStorage.getItem('rebrand-dismissed') }"
      x-show="show"
      x-transition
      class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-center text-sm py-2.5 px-4 relative"
    >
      <span>
        <strong>InfraGPT is now InfraLayer</strong> — same mission, new name.
      </span>
      <button
        @click="show = false; sessionStorage.setItem('rebrand-dismissed', 'true')"
        class="absolute right-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white"
        aria-label="Dismiss"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
